<launch>
	<node name="rvizvisualisation_main" pkg="rviz" type="rviz" output="log" args="-d $(find mission_manager)/config/single_main.rviz" />
    <node name="rvizvisualisation_exp" pkg="rviz" type="rviz" output="log" args="-d $(find mission_manager)/config/single_exp.rviz" />
    <node name="rvizvisualisation_ins_1" pkg="rviz" type="rviz" output="log" args="-d $(find mission_manager)/config/single_ins_1.rviz" />
    <node name="rvizvisualisation_ins_2" pkg="rviz" type="rviz" output="log" args="-d $(find mission_manager)/config/single_ins_2.rviz" />
    <node name="rvizvisualisation_ins_3" pkg="rviz" type="rviz" output="log" args="-d $(find mission_manager)/config/single_ins_3.rviz" />
	<node pkg="tf" type="static_transform_publisher" name="tf_53" args="0 0 0 0 0 0 world navigation 100" />
</launch>