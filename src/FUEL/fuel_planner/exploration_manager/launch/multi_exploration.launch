<launch>
	<node pkg="map_generator" name="map_pub" type="map_pub" output="screen"
		args="$(find map_generator)/resource/modens_sz3.pcd" />

	<node pkg="waypoint_generator" name="waypoint_generator" type="waypoint_generator"
		output="screen">
		<remap from="~odom" to="odom" />
		<remap from="~goal" to="/move_base_simple/goal" />
		<remap from="~traj_start_trigger" to="/traj_start_trigger" />
		<param name="waypoint_type" value="point" />
	</node>

    <node pkg="mission_manager" name="mission_manager" type="mission_manager.py" output="screen">
		<param name="drone_num" value="4" />
	</node>

	<include file="$(find exploration_manager)/launch/single_explorer.xml">
		<arg name="drone_id" value="1" />

		<arg name="map_size_x" value="40.0" />
		<arg name="map_size_y" value="70.0" />
		<arg name="map_size_z" value=" 20.0" />

		<arg name="init_x" value="-8.5" />
		<arg name="init_y" value="-28.5" />
		<arg name="init_z" value="1.0" />

		<arg name="box_min_x" value="-16.0" />
		<arg name="box_min_y" value="-35.0" />
		<arg name="box_min_z" value=" 0.0" />
		<arg name="box_max_x" value="0.0" />
		<arg name="box_max_y" value="-22.0" />
		<arg name="box_max_z" value="17.0" />

		<arg name="odom_topic" value="odom" />
	</include>

	<include file="$(find exploration_manager)/launch/single_explorer.xml">
		<arg name="drone_id" value="2" />

		<arg name="map_size_x" value="26.0" />
		<arg name="map_size_y" value="30.0" />
		<arg name="map_size_z" value="21.0" />

		<arg name="init_x" value="-1" />
		<arg name="init_y" value="-8.5" />
		<arg name="init_z" value="1.0" />

		<arg name="box_min_x" value="-9.0" />
		<arg name="box_min_y" value="-15.0" />
		<arg name="box_min_z" value=" 0.0" />
		<arg name="box_max_x" value="13.0" />
		<arg name="box_max_y" value="-3.0" />
		<arg name="box_max_z" value="20.0" />

		<arg name="odom_topic" value="odom" />
	</include>

	<include file="$(find exploration_manager)/launch/single_explorer.xml">
		<arg name="drone_id" value="3" />

		<arg name="map_size_x" value="50.0" />
		<arg name="map_size_y" value="32.0" />
		<arg name="map_size_z" value="36.0" />

		<arg name="init_x" value="-21.5" />
		<arg name="init_y" value="-14.5" />
		<arg name="init_z" value="1.0" />

		<arg name="box_min_x" value="-22.5" />
		<arg name="box_min_y" value="-15.5" />
		<arg name="box_min_z" value=" 0.0" />
		<arg name="box_max_x" value="-13.5" />
		<arg name="box_max_y" value="-6" />
		<arg name="box_max_z" value="35" />

		<arg name="odom_topic" value="odom" />
	</include>

	<include file="$(find exploration_manager)/launch/single_explorer.xml">
		<arg name="drone_id" value="4" />

		<arg name="map_size_x" value="26.0" />
		<arg name="map_size_y" value="60.0" />
		<arg name="map_size_z" value=" 20.0" />

		<arg name="init_x" value="3" />
		<arg name="init_y" value="-20.5" />
		<arg name="init_z" value="1.0" />

		<arg name="box_min_x" value="2.3" />
		<arg name="box_min_y" value="-29.5" />
		<arg name="box_min_z" value=" 0.0" />
		<arg name="box_max_x" value="12.9" />
		<arg name="box_max_y" value="-17.5" />
		<arg name="box_max_z" value="18.0" />

		<arg name="odom_topic" value="odom" />
	</include>

